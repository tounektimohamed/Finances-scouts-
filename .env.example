# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# WHATSAPP_PROVIDER: Choose 'ultramsg' (free tier available) or 'generic'
WHATSAPP_PROVIDER="ultramsg"

# WHATSAPP_API_URL: Your WhatsApp API endpoint
# For UltraMsg: https://api.ultramsg.com/INSTANCE_ID
WHATSAPP_API_URL=""

# WHATSAPP_API_KEY: Your WhatsApp API authentication token
WHATSAPP_API_KEY=""

# TROOP_NAME: Name of the scout group (appears on PDF receipts)
TROOP_NAME="فوج الكشافة بقرطاج"
